# Frontend Environment Variables (Vite)

# JDoodle API Credentials (for code compilation feature)
# Get your API credentials from: https://www.jdoodle.com/compiler-api
# VITE_JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
# VITE_JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here

# Gemini AI API Key (for AI-powered features)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Murf AI API Key (for text-to-speech features)
# Get your API key from: https://murf.ai
VITE_MURF_API_KEY=your_murf_api_key_here

# Backend API Base URL (optional, defaults to http://localhost:8080)
# VITE_API_BASE_URL=http://localhost:8080
